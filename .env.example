# =====================================================================
# Frontend (Vite)
# =====================================================================
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"

# Base URL the dashboard uses to reach the backend. Leave blank in
# production when the backend is reverse-proxied at the same origin.
VITE_API_BASE_URL="http://localhost:8787/api"

# =====================================================================
# Backend (Express server — server/index.ts)
# =====================================================================
PORT=8787
ALLOWED_ORIGIN="http://localhost:3000"

# ---- Firebase Admin SDK ----
# Either point to a service-account JSON file via GOOGLE_APPLICATION_CREDENTIALS,
# or paste the JSON inline (handy for Cloud Run / Docker secrets).
FIREBASE_PROJECT_ID="gen-lang-client-0398551843"
FIRESTORE_DATABASE_ID="ai-studio-0a136d12-411b-4802-adf1-e34f3ee3ad78"
# Comma-separated allowlist. Only these emails can ever become platform super admins.
PLATFORM_SUPERADMINS="owner@example.com,security@example.com"
# GOOGLE_APPLICATION_CREDENTIALS="/secrets/firebase-admin.json"
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# ---- Encryption (32 bytes, base64-encoded) ----
# Used to encrypt WhatsApp access tokens at rest before they land in Firestore.
# Generate with: `openssl rand -base64 32`
SECRETS_ENCRYPTION_KEY=""

# ---- WhatsApp Cloud API ----
WHATSAPP_API_VERSION="v20.0"
# Verify token shared with Meta in the webhook setup.
WHATSAPP_VERIFY_TOKEN="change-me-strong-random-string"
# App secret from the Meta App dashboard (used to verify x-hub-signature-256).
WHATSAPP_APP_SECRET=""

# ---- n8n master workflow ----
N8N_MASTER_WEBHOOK_URL="https://n8n.example.com/webhook/wassel-master"
# Shared HMAC secret signed onto every dispatch and verified on callbacks.
N8N_SIGNING_SECRET="change-me-strong-random-string"
N8N_TIMEOUT_MS=15000

# ---- Broadcast pipeline ----
BROADCAST_CONCURRENCY=10
